# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# ── Supabase ─────────────────────────────────────────────────────────
# From Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (for Drizzle migrations + server-side queries that need raw SQL)
# Supabase Project Settings → Database → Connection string (use the "session" pooler for migrations)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Email (Microsoft Graph, app-only OAuth) ──────────────────────────
# Used by lib/email/client.ts for all transactional email.
# Requires an Entra ID (Azure AD) app registration with Microsoft Graph
# `Mail.Send` Application permission and admin consent granted. Scope the
# app to MAIL_FROM_USER_ID's mailbox via New-ApplicationAccessPolicy to
# prevent it from being able to send-as any mailbox in the tenant.
# See docs/SETUP.md §4 for the full setup procedure.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
# UPN or object ID of the mailbox to send as.
MAIL_FROM_USER_ID=digital@dastifysolutions.com
MAIL_FROM_NAME=Dastify Connect

# ── Supabase Auth Send Email Hook ────────────────────────────────────
# Routes Supabase Auth emails through our Graph wrapper (app/api/auth/send-email).
# Generated in Supabase dashboard → Auth → Hooks → Send Email Hook. Format: v1,whsec_<base64>.
SEND_EMAIL_HOOK_SECRET=

# ── Cron auth ────────────────────────────────────────────────────────
# Shared secret for scheduled endpoints (/api/cron/notifications, /api/cron/digest).
# Sent as `Authorization: Bearer <CRON_SECRET>`. Generate: openssl rand -base64 32
CRON_SECRET=

# ── Field encryption (pgcrypto) ──────────────────────────────────────
# Used by encrypted-column helpers; rotate carefully (requires re-encrypting columns).
# Generate with: openssl rand -base64 48
PGCRYPTO_SYMMETRIC_KEY=
